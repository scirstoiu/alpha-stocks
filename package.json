{
  "name": "alpha-stocks",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@alpha-stocks/web",
    "dev:mobile": "turbo dev --filter=@alpha-stocks/mobile",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "test": "turbo test"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.0"
    }
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.4.0",
    "vitest": "^4.1.2"
  }
}
