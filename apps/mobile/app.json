{
  "expo": {
    "name": "Alpha Stocks",
    "slug": "alpha-stocks",
    "version": "1.2.7",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "alpha-stocks",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#122864"
    },
    "android": {
      "package": "com.alphastocks.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2556C4"
      }
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Alpha Stocks uses Face ID to secure your account."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fe0883ab-224f-4537-b9ac-a6715399f9dd"
      }
    }
  }
}
